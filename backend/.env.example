# Supabase Configuration
# Get these values from your Supabase project settings

# Project URL (Settings > API > Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Anon/Public key (Settings > API > Project API keys > anon public)
SUPABASE_ANON_KEY=your-anon-key

# Service role key (Settings > API > Project API keys > service_role)
# WARNING: Keep this secret! Only use server-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret (Settings > API > JWT Settings > JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# Application Settings
APP_NAME=Memento API
DEBUG=false
FRONTEND_APP_URL=https://memento-4f4m.vercel.app

# Recognition API key hash mapping (SHA-256 of raw API keys).
# Incoming X-Recognition-Api-Key is hashed and matched against these values.
# If both are unset, recognition API key auth is bypassed (local dev only).
MENTRA_API_KEY_HASH=sha256-of-mentra-recognition-api-key
WEB_API_KEY_HASH=sha256-of-web-frontend-recognition-api-key

# Optional AI summary generation
# Set OPENAI_API_KEY and install `dspy-ai` if you want DSPy-generated summaries.
OPENAI_API_KEY=
PROFILE_SUMMARY_PROVIDER=auto
PROFILE_SUMMARY_MODEL=openai/gpt-4o-mini

# AWS Configuration (for Rekognition facial recognition)
# Get credentials from AWS IAM console
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# S3 Bucket for storing profile photos (optional)
S3_BUCKET_NAME=your-bucket-name

# Email (FastAPI Mail with Gmail SMTP)
# Gmail requires an App Password (not your regular Google password).
MAIL_ENABLED=false
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=Memento
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_VALIDATE_CERTS=true
